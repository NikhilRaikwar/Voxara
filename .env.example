# Required: Musixmatch catalog, lyrics, richsync, subtitles, and charts
MUSIXMATCH_API_KEY=

# Required for vocal isolation and learner speech transcription
ELEVENLABS_API_KEY=

# Optional: cross-platform track popularity enrichment
SONGSTATS_API_KEY=

# Required for lyric fallback translation and runtime UI translation
AI_INTEGRATIONS_OPENAI_BASE_URL=
AI_INTEGRATIONS_OPENAI_API_KEY=

# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
